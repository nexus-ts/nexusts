{
  "name": "@nexusts/core",
  "version": "0.9.2",
  "description": "NexusTS core — MVC + DI + routing + validation + view engine. Install this and you have a working Bun-native app.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./di/safe-reflect": {
      "types": "./src/di/safe-reflect.ts",
      "import": "./src/di/safe-reflect.ts"
    },
    "./di/standard-inject": {
      "types": "./src/di/standard-inject.ts",
      "import": "./src/di/standard-inject.ts"
    }
  },
  "files": [
    "dist",
    "src/di",
    "README.md"
  ],
  "bin": {
    "nx": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "bun run ../../build.ts"
  },
  "keywords": [
    "nexusts",
    "framework",
    "bun",
    "mvc",
    "di",
    "hono",
    "typescript",
    "decorator"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@nexusts/cli": "file:../cli",
    "@nexusts/view": "file:../view",
    "hono": "^4.6.0",
    "rendu": "^0.1.0",
    "zod": "^3.23.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nexus-ts/nexusts.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/nexus-ts/nexusts#readme",
  "bugs": {
    "url": "https://github.com/nexus-ts/nexusts/issues"
  }
}
