{
  "name": "nexusts",
  "version": "0.7.3",
  "description": "NexusTS — Bun-native fullstack framework. Multi-package monorepo. See packages/* for individual modules.",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "build:all": "bun run build.ts",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check packages/cli/ tests/cli/",
    "lint:fix": "biome check --write packages/cli/ tests/cli/",
    "nx": "bun packages/cli/src/index.ts",
    "examples:smoke": "vitest run tests/examples/smoke.test.ts",
    "examples:clean": "bash scripts/clean-examples.sh",
    "publish:all": "bun run scripts/publish.ts",
    "publish:dry-run": "bun run scripts/publish.ts --dry-run"
  },
  "devDependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@inertiajs/react": "^3.4.0",
    "@inertiajs/vue3": "^3.4.0",
    "@opentelemetry/api": "^1.9.0",
    "@types/bun": "^1.3.0",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.18.1",
    "@vue/server-renderer": "^3.5.38",
    "bullmq": "^5.79.0",
    "drizzle-orm": "^0.45.0",
    "eta": "^4.6.0",
    "graphql": "^17.0.1",
    "hono": "^4.12.27",
    "ioredis": "^5.11.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "rendu": "^0.1.0",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.5",
    "vue": "^3.5.38",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "license": "MIT"
}
