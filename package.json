{
  "name": "nexusjs",
  "version": "0.1.0",
  "description": "Bun Native Fullstack Framework - NestJS structure + Adonis productivity + Hono edge performance",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./decorators": {
      "types": "./dist/core/decorators/index.d.ts",
      "import": "./dist/core/decorators/index.js"
    },
    "./di": {
      "types": "./dist/core/di/index.d.ts",
      "import": "./dist/core/di/index.js"
    },
    "./http": {
      "types": "./dist/core/http/index.d.ts",
      "import": "./dist/core/http/index.js"
    },
    "./validation": {
      "types": "./dist/core/validation/index.d.ts",
      "import": "./dist/core/validation/index.js"
    },
    "./view": {
      "types": "./dist/core/view/index.d.ts",
      "import": "./dist/core/view/index.js"
    },
    "./orm": {
      "types": "./dist/core/orm/index.d.ts",
      "import": "./dist/core/orm/index.js"
    },
    "./runtime": {
      "types": "./dist/core/runtime/index.d.ts",
      "import": "./dist/core/runtime/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "bin": {
    "nx": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun --hot src/app/main.ts",
    "start": "bun src/app/main.ts",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'Add eslint later'",
    "nx": "bun src/cli/index.ts",
    "make:controller": "bun scripts/make-controller.ts",
    "make:service": "bun scripts/make-service.ts",
    "make:module": "bun scripts/make-module.ts"
  },
  "keywords": [
    "framework",
    "bun",
    "hono",
    "cloudflare",
    "mvc",
    "nestjs",
    "adonis",
    "edge",
    "typescript",
    "decorator"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "reflect-metadata": "^0.2.2",
    "rendu": "^0.1.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "better-auth": "^1.6.20",
    "drizzle-orm": "^0.36.0"
  },
  "peerDependencies": {
    "zod": "^3.23.8",
    "better-auth": "^1.6.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": false
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "^1.1.10",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.5"
  }
}