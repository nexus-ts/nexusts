    },
    "./tracing": {
      "types": "./dist/tracing/index.d.ts",
      "import": "./dist/tracing/index.js"
    }
  },
  "bin": {
    "nx": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun --hot src/app/main.ts",
    "start": "bun src/app/main.ts",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/cli/ tests/cli/",
    "lint:fix": "biome check --write src/cli/ tests/cli/",
    "nx": "bun src/cli/index.ts",
    "make:controller": "bun scripts/make-controller.ts",
    "make:service": "bun scripts/make-service.ts",
    "make:module": "bun scripts/make-module.ts"
  },
  "keywords": [
    "framework",
    "bun",
    "hono",
    "cloudflare",
    "mvc",
    "nestjs",
    "adonis",
    "edge",
    "typescript",
    "decorator",
    "drizzle"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
