{
  "name": "nexusts",
  "version": "0.9.14",
  "description": "NexusTS — Bun-native fullstack framework. Multi-package monorepo. See packages/* for individual modules.",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "build:all": "bun run build.ts",
    "test": "bun test tests/cache/cache.test.ts tests/core/router.test.ts tests/core/global.test.ts tests/core/application.test.ts tests/e2e/app.test.ts tests/graphql/ tests/grpc/ tests/resilience/ tests/feature-flag/ tests/runtime/ tests/core/exception-filters.test.ts tests/core/guards.test.ts tests/core/interceptors.test.ts tests/core/lifecycle.test.ts tests/drizzle/reexports.test.ts",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit --skipLibCheck --project tsconfig.typecheck.json",
    "lint": "biome lint packages/cli/ tests/cli/",
    "lint:fix": "biome check --write packages/cli/ tests/cli/",
    "nx": "bun packages/cli/src/index.ts",
    "examples:smoke": "bun test tests/examples/smoke.test.ts",
    "examples:clean": "bash scripts/clean-examples.sh",
    "publish:all": "bun run scripts/publish.ts",
    "publish:dry-run": "bun run scripts/publish.ts --dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@inertiajs/react": "^3.4.0",
    "@inertiajs/vue3": "^3.4.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vue/server-renderer": "^3.5.38",
    "better-sqlite3": "^12.11.1",
    "bullmq": "^5.79.0",
    "drizzle-orm": "^0.45.0",
    "eta": "^4.6.0",
    "graphql": "^17.0.1",
    "hono": "^4.12.27",
    "ioredis": "^5.11.1",
    "kysely": "0.27.4",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rendu": "^0.1.0",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vue": "^3.5.38",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "license": "MIT"
}
