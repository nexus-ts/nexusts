{
  "name": "@nexusts/drizzle",
  "version": "0.7.7",
  "description": "Drizzle ORM integration (default ORM, 5 dialects)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "bun run ../../build.ts"
  },
  "keywords": ["nexusts", "framework", "bun"],
  "license": "MIT",
  "peerDependencies": { "drizzle-orm": "^0.45.0" },
  "peerDependenciesMeta": { "drizzle-orm": { "optional": true } },
  "dependencies": {
    "@nexusts/core": "file:../core"
  }
}
